# Program that creates a dictionary from two lists

list_one = []
list_two = []

print("Input items for list_one")

while True:
    item = input("Type an item: ")
    list_one.append(item)

    status = input("Are you done? (yes/no): ").lower()
    if status == "yes":
        break

print()

print("Input items for list_two")

while True:
    item = input("Type an item: ")
    list_two.append(item)

    status = input("Are you done? (yes/no): ").lower()
    if status == "yes":
        break

# Check if both lists are equal
if len(list_one) != len(list_two):
    print("Lists are not the same length.")
else:
    my_dictionary = {}

    for i in range(len(list_one)):
        my_dictionary[list_one[i]] = list_two[i]

    print("Generated dictionary:")
    print(my_dictionary)